13.	Сумма элементов массива

```cpp
Int main()
{
    Float a[100];
    Int n;
    Cout << “n = “;
    Cin >> n;
    Float s = 0;
    For (int i = 0; i < n; ++i)
    {
        Cout << “a[“ << i << “] = “;
